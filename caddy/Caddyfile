sky0cloud.dpdns.org {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Cross-Origin-Resource-Policy "cross-origin"
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization"
    }

    # 1. Handle Well-Known first
    handle_path /.well-known/matrix/* {
        root * /srv/well-known/matrix
        header Content-Type application/json
        file_server
    }

    # 2. Proxy Matrix API - Use 'handle' to isolate these requests
    handle /_matrix/* {
        reverse_proxy http://tuwunel:6167
    }
    handle /_synapse/client/* {
        reverse_proxy http://tuwunel:6167
    }

    # 3. Handle Static Element App
    handle {
        root * /srv/element
        # try_files without a redirect: if file not found, serve index.html
        try_files {path} {path}/ /index.html
        file_server
    }
}
