http://sky0cloud.dpdns.org {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        
        # --- CORS: Only add if missing ---
        ?Access-Control-Allow-Origin *
        ?Access-Control-Allow-Methods "GET, POST, OPTIONS"
        ?Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization"
        ?Access-Control-Expose-Headers "Content-Length, Content-Type, Date, Server"
        
        # Keep this for local Web UI media display
        Cross-Origin-Resource-Policy "cross-origin"
    }

    # Federation and Client Discovery
    handle_path /.well-known/matrix/* {
        root * /srv/well-known/matrix
        header Content-Type application/json
        file_server
    }

    # Route all Matrix API and Media traffic to Tuwunel
    @matrix path /_matrix/* /_synapse/*
    handle @matrix {
        reverse_proxy tuwunel:6167 {
            header_up X-Forwarded-Proto https
        }
    }

    # Redirect base domain to Element login
    @root path /
    redir @root https://sky0cloud.dpdns.org/#/login 302

    # Route everything else (The Web UI) to the Element container
    handle {
        reverse_proxy element-web:80 {
            header_up X-Forwarded-Proto https
        }
    }
}
