sky0cloud.dpdns.org {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Cross-Origin-Resource-Policy "cross-origin"

        # Basic CORS for web client/media access
        ?Access-Control-Allow-Origin *
        ?Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        ?Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization"
    }

    # Matrix delegation endpoints (for clients + federation)
    handle_path /.well-known/matrix/* {
        root * /srv/well-known/matrix
        header Content-Type application/json
        file_server
    }

    # Matrix API + media + sync traffic to Tuwunel
    @matrix_api path /_matrix/* /_synapse/client/*
    handle @matrix_api {
        reverse_proxy tuwunel:6167 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Host {host}
        }
    }

    # Root domain should externally redirect to login path (once, avoids hash-route loops)
    @root_login_redirect {
        path /
        not header Cookie *sky0cloud_login_redirected=1*
    }
    handle @root_login_redirect {
        header Set-Cookie "sky0cloud_login_redirected=1; Path=/; Max-Age=300; SameSite=Lax"
        redir https://sky0cloud.dpdns.org/#/login 302
    }

    # Keep /element/ explicitly routable for static web client access
    handle_path /element/* {
        reverse_proxy element-web:80 {
            header_up X-Forwarded-Proto https
        }
    }

    # Serve Element for all other web UI paths
    handle {
        reverse_proxy element-web:80 {
            header_up X-Forwarded-Proto https
        }
    }
}
