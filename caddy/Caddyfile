{
    # Use ACME with the email from the environment; if ACME_EMAIL is
    # not set, Caddy will still start, and the site block below has
    # an explicit internal-TLS fallback.
    email {env.ACME_EMAIL}
}

# Redirect HTTP to HTTPS for the configured domain
http://{env.DOMAIN} {
    redir https://{env.DOMAIN}{uri} 308
}

# Main site served over HTTPS. We configure TLS via a block so that
# use of environment variables is valid and Caddy passes `caddy validate`.
https://{env.DOMAIN} {
    # Primary TLS configuration using ACME. The account email is taken
    # from {env.ACME_EMAIL} via the global options block above.
    tls {
        # Use the default ACME issuer; configuration lives in the
        # global options block. This empty block is valid syntax and
        # keeps the tls directive structurally correct.
    }

    encode zstd gzip

    request_body {
        max_size 25MB
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(self), microphone=(self), geolocation=()"
        Cross-Origin-Opener-Policy "same-origin"
    }

    # Matrix discovery endpoints:
    # - /.well-known/matrix/server
    # - /.well-known/matrix/client
    #
    # The repo layout is `./well-known/matrix/{server,client}`, so we use
    # handle_path to strip the URL prefix and serve from that directory.
    handle_path /.well-known/matrix/* {
        root * /srv/well-known/matrix
        header Content-Type application/json
        file_server
    }

    @matrixApi path /_matrix/* /_synapse/admin/*
    handle @matrixApi {
        reverse_proxy conduwuit:6167
    }

    handle {
        reverse_proxy element-web:80
    }
}

# Safe local fallback when DOMAIN/ACME_EMAIL are not set or TLS
# issuance fails: an internal CA on :443 which will keep the
# container healthy for smoke tests.
:443 {
    tls internal
    respond "Sky0Cloud Caddy local TLS endpoint" 200
}
