sky0cloud.dpdns.org {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Cross-Origin-Resource-Policy "cross-origin"

        ?Access-Control-Allow-Origin *
        ?Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        ?Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization"
    }

    # Matrix client and federation discovery files
    handle_path /.well-known/matrix/* {
        root * /srv/well-known/matrix
        header Content-Type application/json
        file_server
    }

    # Matrix API/media/client routing to Tuwunel
    @matrix_api path /_matrix/* /_synapse/client/*
    handle @matrix_api {
        reverse_proxy http://tuwunel:6167 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Host {host}
        }
    }

    # Static Element app served directly from repository folder mount
    root * /srv/element

    # HDD-friendly cache policy
    @static_assets path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.webp *.ico *.woff *.woff2 *.ttf *.map
    header @static_assets Cache-Control "public, max-age=604800, immutable"

    @app_shell path / /index.html /config.json /manifest.json /sw.js
    header @app_shell Cache-Control "public, max-age=300"

    # SPA fallback for hash router/login page
    try_files {path} /index.html
    file_server
}
