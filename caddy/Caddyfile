sky0cloud.dpdns.org {
    encode zstd gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
        Cross-Origin-Resource-Policy "cross-origin"
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Origin, X-Requested-With, Content-Type, Accept, Authorization"
    }

    # Matrix Federation & Client discovery
    handle_path /.well-known/matrix/* {
        root * /srv/well-known/matrix
        header Content-Type application/json
        file_server
    }

    # Proxy to Tuwunel (Matrix Core)
    @matrix_api path /_matrix/* /_synapse/client/*
    handle @matrix_api {
        reverse_proxy http://tuwunel:6167
    }

    # Static Element App
    root * /srv/element
    
    # SPA routing to prevent the "Too many redirects" loop
    try_files {path} /index.html
    file_server
}
