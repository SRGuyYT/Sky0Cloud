http://sky0cloud.dpdns.org {
    redir https://sky0cloud.dpdns.org{uri}
}

https://sky0cloud.dpdns.org {
    encode gzip zstd

    handle_path /.well-known/matrix/* {
        root * /srv/well-known/matrix
        header Content-Type application/json
        file_server
    }

    @matrixApi path /_matrix/* /_synapse/admin/*
    handle @matrixApi {
        reverse_proxy conduwuit:6167
    }

    handle {
        reverse_proxy element-web:80
    }
}
