    email chapmlinks@gmail.com
}

sky0cloud.dpdns.org:443 {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

    # Increase max upload size to 500MB (Caddy default is usually fine, but good to be sure)
    request_body {
        max_size 500MB
    }

    # Security Headers - Specifically allowing media and blobs
    header {
        # Allow images, video, and audio from 'self' and blob: (for encrypted media)
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' wss:; style-src 'self' 'unsafe-inline';"
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
    }

    encode zstd gzip
    root * /srv/element

    # Matrix Discovery
    handle /.well-known/matrix/server {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
    }

    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
    }

    # Proxy EVERYTHING under /_matrix (Media, Client, Federation)
    handle /_matrix/* {
        reverse_proxy tuwunel:6167
    }

    # Element Web UI
    handle {
        try_files {path} {path}/ /index.html
        file_server
    }
}
