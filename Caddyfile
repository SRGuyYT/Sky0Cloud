{
    email chapmlinks@gmail.com
    # Disable automatic HTTP->HTTPS redirects because the Tunnel handles entry
    auto_https disable_redirects
}

https://sky0cloud.dpdns.org:443 {

    request_body {
        max_size 200MB
    }

    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Authorization, Content-Type, Origin"
        # CSP fixed for Cloudflare and Element scripts
        Content-Security-Policy "default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.recaptcha.net https://www.gstatic.com https://static.cloudflareinsights.com; connect-src 'self' https://sky0cloud.dpdns.org wss://sky0cloud.dpdns.org https://static.cloudflareinsights.com;"
    }

    encode zstd gzip

    # Matrix Discovery
    handle /.well-known/matrix/* {
        header Access-Control-Allow-Origin *
        header Content-Type application/json
        reverse_proxy http://tuwunel:6167
    }

    # THE 403 FIX: Matrix Media & API
    handle /_matrix/* {
        reverse_proxy http://tuwunel:6167 {
            header_up Host sky0cloud.dpdns.org
            header_up X-Forwarded-Proto https
        }
    }

    # Element Web
    handle {
        reverse_proxy http://element-web:80
    }
}
