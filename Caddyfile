{
    email chapmlinks@gmail.com
    auto_https disable_redirects
}

sky0cloud.dpdns.org {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key

    request_body {
        max_size 100MB
    }

    encode zstd gzip

    header {
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-eval'; img-src 'self' data: blob:; media-src 'self' blob:; connect-src 'self' wss: https:; style-src 'self' 'unsafe-inline';"
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
    }

    # Matrix discovery
    handle /.well-known/matrix/server {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
    }

    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
    }

    # Matrix API (Tuwunel)
    handle /_matrix/* {
        reverse_proxy sky0cloud-tuwunel-1:6167
    }

    # Element Web UI
    handle {
        reverse_proxy sky0cloud-element-web-1:8080
    }
}
