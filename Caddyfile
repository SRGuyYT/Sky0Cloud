{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {

    encode gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        # CSP is optional; keep loose for Element Web if needed, tighten later
        Content-Security-Policy "default-src 'self' data: blob: 'unsafe-inline' 'unsafe-eval';"
    }

    # Matrix discovery
    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{
            "m.homeserver": {"base_url": "https://sky0cloud.dpdns.org"}
        }` 200
    }

    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{
            "m.server": "sky0cloud.dpdns.org:443"
        }` 200
    }

    # Matrix API + media + federation
    handle /_matrix/* {
        request_body {
            max_size 500MB
        }
        reverse_proxy tuwunel:6167
    }

    handle /_synapse/* {
        reverse_proxy tuwunel:6167
    }

    # Element web (default catch-all)
    handle {
        reverse_proxy element-web:80
    }
}
