{
    auto_https off
}

# Use :80 as a catch-all. Caddy will serve this to ANY request on port 80.
:80 {
    encode gzip
    root * /srv/element

    # 1. Server Discovery
    handle_path /.well-known/matrix/* {
        root * /srv/element/.well-known/matrix
        header Access-Control-Allow-Origin *
        file_server
    }

    # 2. Custom Branding
    @branding path /config.json /welcome.html /icon.png /background.jpg
    handle @branding {
        file_server
    }

    # 3. Matrix API Proxy
    handle /_matrix/* {
        reverse_proxy tuwunel:6167
    }

    # 4. Main App
    handle {
        try_files {path} {path}/ /index.html
        file_server
    }
}
