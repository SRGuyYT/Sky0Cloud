{
    servers {
        trusted_proxies static \
            173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 \
            141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 \
            197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 \
            104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 \
            2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 \
            2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
    }
}

:80 {
    encode zstd gzip

    @from_cf header CF-Connecting-IP *
    request_header @from_cf X-Forwarded-For {http.request.header.CF-Connecting-IP}
    request_header @from_cf X-Real-IP {http.request.header.CF-Connecting-IP}

    handle_path /.well-known/matrix/client {
        header Content-Type "application/json"
        header Access-Control-Allow-Origin "*"
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}`
    }

    handle_path /.well-known/element/element.json {
        header Content-Type "application/json"
        header Access-Control-Allow-Origin "*"
        respond `{"im.vector.app.devices":{"apple":{"app_id":"793422880"}}}`
    }

    @root path /
    redir @root /welcome.html 302

    handle /_matrix/client/v3/sync* {
        reverse_proxy conduwuit-skyservers:8008 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
            header_up X-Real-IP {http.request.header.CF-Connecting-IP}
            flush_interval -1
            request_buffers 0
            response_buffers 0
            transport http {
                dial_timeout 30s
                response_header_timeout 300s
            }
        }
    }

    @push path /_matrix/push* /_matrix/client/v3/push* /_matrix/client/v3/pushrules*
    handle @push {
        reverse_proxy conduwuit-skyservers:8008 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
            header_up X-Real-IP {http.request.header.CF-Connecting-IP}
            transport http {
                dial_timeout 30s
                response_header_timeout 300s
            }
        }
    }

    handle /_matrix/* {
        reverse_proxy conduwuit-skyservers:8008 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
            header_up X-Real-IP {http.request.header.CF-Connecting-IP}
            transport http {
                dial_timeout 30s
                response_header_timeout 300s
            }
        }
    }

    handle /_synapse/client/* {
        reverse_proxy conduwuit-skyservers:8008 {
            header_up X-Forwarded-Proto https
            header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
            header_up X-Real-IP {http.request.header.CF-Connecting-IP}
            transport http {
                dial_timeout 30s
                response_header_timeout 300s
            }
        }
    }

    handle /sw.js {
        header Service-Worker-Allowed "/"
        header Cache-Control "no-cache, no-store, must-revalidate"
        reverse_proxy element-skyservers:80
    }

    @welcome path /welcome.html /welcome.js /welcome-style.css /manifest.json /sw.js /logo.png /apple-touch-icon.png /background.jpg
    handle @welcome {
        reverse_proxy element-skyservers:80
    }

    handle {
        reverse_proxy element-skyservers:80

        header {
            Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
            X-Content-Type-Options "nosniff"
            X-Frame-Options "SAMEORIGIN"
            Referrer-Policy "strict-origin-when-cross-origin"
        }
    }
}
