https://sky0cloud.dpdns.org {
    encode gzip

    # 1. Server Discovery
    handle_path /.well-known/matrix/* {
        root * /branding/.well-known/matrix
        header Access-Control-Allow-Origin *
        file_server
    }

    # 2. Branding Overrides (Branding folder)
    # This serves config.json and welcome.html from the /branding mount
    handle /config.json {
        root * /branding
        file_server
    }
    handle /welcome.html {
        root * /branding
        file_server
    }

    # 3. Matrix API Proxy
    handle /_matrix/* {
        reverse_proxy tuwunel:6167
    }

    # 4. Main Element App
    handle {
        root * /srv/element
        file_server
        try_files {path} {path}/ /index.html
    }
}
