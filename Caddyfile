{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {
    # 1. Force Discovery (Fixes "Can't connect to homeserver")
    handle /.well-known/matrix/client {
        header Access-Control-Allow-Origin *
        header Content-Type application/json
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
    }

    # 2. The Media & API "Brute Force"
    # We remove the "header_up Authorization" and only pass the Host.
    # This stops the server from over-thinking the security of the request.
    handle /_matrix/* {
        reverse_proxy http://tuwunel:6167 {
            header_up Host sky0cloud.dpdns.org
            header_up X-Forwarded-Proto https
        }
    }

    # 3. Admin Panel (Fixed path)
    handle_path /admin* {
        reverse_proxy http://synapse-admin:80
    }

    # 4. Element Web (The frontend)
    handle {
        reverse_proxy http://element-web:80
    }

    # 5. Global "Allow Everything" Header
    # This overrides Tuwunel's security to ensure the browser never blocks media
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
        Access-Control-Allow-Headers "*"
    }
}
