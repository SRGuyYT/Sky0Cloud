:80 {
    encode zstd gzip

    # 1. FIX THE 404: Redirect the empty root to the welcome page
    redir / /welcome.html 302

    # 2. Well-Knowns (Matrix Handshake)
    handle_path /.well-known/matrix/client {
        header Access-Control-Allow-Origin "*"
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}`
    }

    # 3. Matrix API (Conduwuit) - Optimized for Notifications
    handle /_matrix/* {
        reverse_proxy conduwuit-skyservers:8008 {
            flush_interval -1
            transport http {
                response_header_timeout 300s
            }
        }
    }

    # 4. Welcome Assets (Static)
    @welcome path /welcome.html /welcome.js /welcome-style.css /manifest.json /logo.png /apple-touch-icon.png /background.jpg /sw.js
    handle @welcome {
        reverse_proxy element-skyservers:80
    }

    # 5. Fallback (The actual Element Web App)
    handle {
        reverse_proxy element-skyservers:80
    }
}
