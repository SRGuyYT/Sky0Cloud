{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {

    encode gzip

    # MATRIX DISCOVERY (THIS IS THE IMPORTANT FIX)
    handle /.well-known/matrix/client {
        respond `{
          "m.homeserver": {
            "base_url": "http://sky0cloud.dpdns.org"
          }
        }` 200 {
            content_type application/json
        }
    }

    handle /.well-known/matrix/server {
        respond `{
          "m.server": "sky0cloud.dpdns.org:80"
        }` 200 {
            content_type application/json
        }
    }

    # MATRIX API
    handle_path /_matrix/* {
        reverse_proxy tuwunel:6167
    }

    handle_path /_synapse/* {
        reverse_proxy tuwunel:6167
    }

    # ELEMENT WEB
    handle {
        reverse_proxy element-web:80
    }
}
