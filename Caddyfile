{
    email chapmlinks@gmail.com
    auto_https off
}

:80 {

    encode gzip

    # Matrix client discovery
    handle /.well-known/matrix/client {
        respond `{
          "m.homeserver": {
            "base_url": "http://sky0cloud.dpdns.org"
          }
        }` 200 {
            header Content-Type application/json
            header Access-Control-Allow-Origin *
        }
    }

    # Matrix server discovery (federation)
    handle /.well-known/matrix/server {
        respond `{
          "m.server": "sky0cloud.dpdns.org:80"
        }` 200 {
            header Content-Type application/json
        }
    }

    # Matrix API + MEDIA + federation
    handle /_matrix/* {
        reverse_proxy tuwunel:6167
    }

    handle /_synapse/* {
        reverse_proxy tuwunel:6167
    }

    # Element web client
    handle {
        reverse_proxy element-web:80
    }
}
