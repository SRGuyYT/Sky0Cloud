{
    auto_https off
    email chapmlinks@gmail.com
    acme_ca https://acme.zerossl.com/v2/DV90

    acme_eab {
        key_id uWbcH3X52RrjW42TJECv9A
        mac_key kHNR7DP4uoJA_jLmD8su0g6JN-V16gj08LX8PoyxR3FbHRE6WRagAn2HOvRbgTKpoTsmqC5bbUSbwQji3WGOkw
    }
}

:80 {

    encode zstd gzip

    request_body {
        max_size 1GB
    }

    header {
        Content-Security-Policy "default-src * data: blob: 'unsafe-inline' 'unsafe-eval';"
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Access-Control-Allow-Origin *
    }

    # Matrix server discovery
    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
    }

    # Matrix client discovery
    handle /.well-known/matrix/client {
        header Content-Type application/json
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
    }

    # Matrix API → Tuwunel
    handle /_matrix/* {
        reverse_proxy http://tuwunel:6167 {
            header_up X-Forwarded-For {remote}
            header_up X-Forwarded-Proto https
            header_up Host {host}
        }
    }

    # Admin GUI (inside Docker, internal port 8080 is fine)
    handle /admin/* {
        reverse_proxy http://admin-gui:8080
    }

    # NeoBoard
    handle /neoboard/* {
        reverse_proxy http://neoboard:8080
    }

    # Matrix Poll
    handle /poll/* {
        reverse_proxy http://matrix-poll:8080
    }

    # Bots (path-based routing)
    handle /bots/baibot/* {
        reverse_proxy http://baibot:80
    }
    handle /bots/mjolnir/* {
        reverse_proxy http://mjolnir:80
    }
    handle /bots/eno/* {
        reverse_proxy http://matrix-eno-bot:80
    }
    handle /bots/registration/* {
        reverse_proxy http://matrix-registration-bot:80
    }

    # Element Web as fallback
    handle {
        reverse_proxy http://element-web:80
    }
}
