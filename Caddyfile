{
    email chapmlinks@gmail.com
    auto_https disable_redirects
}

sky0cloud.dpdns.org {

    encode zstd gzip

    request_body {
        max_size 100MB
    }

    header {
        # VERY permissive CSP for Matrix/Element (prevents media + federation breakage)
        Content-Security-Policy "default-src * data: blob: 'unsafe-inline' 'unsafe-eval';"

        # Security (safe to keep)
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN

        # CORS (important for Matrix + media)
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers *
    }

    # Handle preflight requests (important for uploads/media)
    @options method OPTIONS
    respond @options 204

    # Matrix discovery
    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server":"sky0cloud.dpdns.org:443"}` 200
    }

    handle /.well-known/matrix/client {
        header Content-Type application/json
        respond `{"m.homeserver":{"base_url":"https://sky0cloud.dpdns.org"}}` 200
    }

    # Matrix backend (media + API)
    handle /_matrix/* {
        reverse_proxy tuwunel:6167 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Element web
    handle {
        reverse_proxy element-web:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
}
