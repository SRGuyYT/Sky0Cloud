{
    email chapmlinks@gmail.com
    # Keep off if Cloudflare is handling SSL
    auto_https off 
}

sky0cloud.dpdns.org:80 {
    encode gzip

    # Global headers to allow media display and security
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Authorization, Content-Type, Origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        Content-Security-Policy "default-src 'self' data: blob: 'unsafe-inline' 'unsafe-eval' https://sky0cloud.dpdns.org;"
    }

    # Matrix discovery
    handle /.well-known/matrix/client {
        header Content-Type application/json
        header Access-Control-Allow-Origin *
        respond `{"m.homeserver": {"base_url": "https://sky0cloud.dpdns.org"}}` 200
    }

    handle /.well-known/matrix/server {
        header Content-Type application/json
        respond `{"m.server": "sky0cloud.dpdns.org:443"}` 200
    }

    # Matrix API & Media
    handle /_matrix/* {
        request_body {
            max_size 500MB
        }
        reverse_proxy tuwunel:6167 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
        }
    }

    handle /_synapse/* {
        reverse_proxy tuwunel:6167
    }

    # Element Web
    handle {
        reverse_proxy element-web:80
    }
}
