# Mailgun SMTP (used by [email] in tuwunel.toml)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@YOUR_MAILGUN_DOMAIN
SMTP_PASS=replace_with_mailgun_smtp_password
SMTP_FROM=Sky0Cloud <noreply@YOUR_MAILGUN_DOMAIN>

# TLS registration email for Caddy/ACME
ACME_EMAIL=official@no-reply.skyservers.qzz.io
